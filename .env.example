DEBUG=true

# --- File env ---
# Development: đặt các biến trong `.env.local` (gitignored).
# Production trên VPS: một file `.env` duy nhất (xem README).
# Ghi đè: ENV_FILE=...

# Production: bắt buộc — tối thiểu 16 ký tự, không dùng ví dụ dưới đây
JWT_SECRET=your-jwt-secret-min-16-chars
SESSION_SECRET=your-session-secret-min-16-chars
# JWT_TTL=1d

# Legacy — chỉ dùng nếu chưa đổi sang JWT_SECRET (ưu tiên JWT_SECRET)
# JWT_SECRET_KEY=

# --- OAuth / CORS ---
# FRONTEND_URL=https://serial.toolhub.app
# FRONTEND_URLS=https://serial.toolhub.app,http://localhost:5173
# GOOGLE_CALLBACK_URL=https://api.toolhub.app/api/auth/google/callback
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

DATABASE_ENV=development

DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_NAME=your_database
DATABASE_USERNAME=your_user
DATABASE_PASSWORD=your_password

DATABASE_TEST_HOST=localhost
DATABASE_TEST_PORT=3308
DATABASE_TEST_NAME=
DATABASE_TEST_USERNAME=
DATABASE_TEST_PASSWORD=

DATABASE_SOCKET=

# Firebase Admin — không commit serviceAccountKey.json
FIREBASE_SERVICE_ACCOUNT_PATH=firebase_mgnt/serviceAccountKey.json
# FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
# FIREBASE_SCENARIOS_COLLECTION=scenarios
# FIREBASE_STORAGE_ATTACHMENTS_PREFIX=attachments
# FIREBASE_STORAGE_SCENARIO_JSON_PREFIX=scenario-json
# FIREBASE_STORAGE_MAX_MB=5

# Rate-limit — Redis là store chính khi scale ngang (bắt buộc production multi-replica)
# RATE_LIMIT_REDIS_URL=redis://127.0.0.1:6379/0

# Object upload: local (mặc định) hoặc s3 (MinIO/AWS — cần @aws-sdk/client-s3 hoặc simulate)
# UPLOAD_STORAGE_DRIVER=local
# UPLOAD_LOCAL_DIR=uploads
# API_BASE_URL=http://localhost:2999
# UPLOAD_STORAGE_DRIVER=s3
# UPLOAD_S3_BUCKET=serial-commander
# UPLOAD_S3_REGION=ap-southeast-1
# UPLOAD_S3_ENDPOINT=http://127.0.0.1:9000
# UPLOAD_S3_PUBLIC_BASE_URL=http://127.0.0.1:9000/serial-commander
# UPLOAD_S3_ACCESS_KEY_ID=
# UPLOAD_S3_SECRET_ACCESS_KEY=
# UPLOAD_S3_SIMULATE_LOCAL=true
# Phiên MQTT remote (POST /api/remote/session) — ưu tiên Redis TTL 2h
# REMOTE_SESSION_REDIS_URL=redis://127.0.0.1:6379/4
# REMOTE_SESSION_TTL_SECONDS=7200
# REMOTE_SESSION_CREATE_PER_MIN=20
# REMOTE_SESSION_VERIFY_PER_MIN=60
# Đồng bộ user broker Mosquitto (username=sessionId, password=mqttPasswordToken).
# Đường dẫn tương đối resolve theo thư mục WebAPI (không phụ thuộc cwd). Thiếu CLI: thử Docker eclipse-mosquitto:2.
# MQTT_PASSWD_FILE=../docker/mosquitto/passwd
# Dev (NODE_ENV≠production): sau khi ghi passwd API tự HUP sc-mqtt-demo rồi sc-mqtt để reload file.
# Production chỉ HUP khi đặt: MQTT_BROKER_HUP_CONTAINER=tên_container
# Bật giới hạn tốc độ khi NODE_ENV=test (vd. test contract 429). Mặc định tắt trong Jest.
# RATE_LIMIT_IN_TEST=1
# SESSION_REDIS_URL=redis://127.0.0.1:6379/1

# OTP hashing and cleanup
# OTP_CODE_PEPPER=change-this-secret-pepper
# AUTH_CODE_CLEANUP_ENABLED=true
# AUTH_CODE_CLEANUP_INTERVAL_MINUTES=60
# AUTH_CODE_USED_RETENTION_DAYS=7
# AUTH_CODE_CLEANUP_REDIS_URL=redis://127.0.0.1:6379/2
# Outbox Redis queue (MySQL meta → queue:scenario_sync → worker batch Firestore)
# SCENARIO_OUTBOX_REDIS_URL=redis://127.0.0.1:6379/3
# SCENARIO_OUTBOX_WORKER_ENABLED=true
# SCENARIO_OUTBOX_POLL_MS=1000
# SCENARIO_OUTBOX_BATCH_SIZE=10
# Job legacy SyncJobs table (tắt nếu chỉ dùng outbox Redis)
# SCENARIO_SYNC_JOB_ENABLED=false
# SCENARIO_SYNC_ENABLED=true
# SCENARIO_SYNC_INTERVAL_MINUTES=5
# SCENARIO_SYNC_REDIS_URL=redis://127.0.0.1:6379/3
# Redis dùng chung cho mọi scheduler (ưu tiên hơn URL riêng từng job)
# SCHEDULER_SHARED_REDIS_URL=redis://127.0.0.1:6379/0
# Production nhiều replica: bắt buộc Redis lock, không chạy body nếu thiếu Redis
# SCHEDULER_STRICT_REPLICA_MODE=true
# (tương đương) JOB_SCHEDULER_REQUIRE_REDIS=true
# Ngưỡng cảnh báo/metric: batch SyncJobs chạy lâu hơn N ms (0 = tắt)
# SYNC_JOB_BATCH_BUDGET_MS=30000
# CI=true will skip local cleanup scheduler

# Email (production): SMTP hoặc Gmail app password — xem utils/emailService.js
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASSWORD=
# GMAIL_USER=
# GMAIL_APP_PASSWORD=

# --- Logging & observability ---
# LOG_FORMAT=json
# LOG_LEVEL=info
# VALIDATE_API_RESPONSES=1

# OpenTelemetry traces (bật sau khi có collector, vd. Jaeger OTLP HTTP)
# OTEL_ENABLED=true
# OTEL_SERVICE_NAME=serial-commander-webapi
# OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318
# Tắt export metric/log SDK đi kèm (mặc định code set none nếu không cấu hình)
# OTEL_METRICS_EXPORTER=none
# OTEL_LOGS_EXPORTER=none
