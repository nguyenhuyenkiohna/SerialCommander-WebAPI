# Mẫu production — copy thành .env trên VPS (SerialCommander-WebAPI-main/.env)
# Không commit file có secret thật.

DATABASE_ENV=production
NODE_ENV=production
DEBUG=false

# DB — dùng DATABASE_* hoặc PROD_DB_* (code chấp nhận cả hai)
DATABASE_HOST=mysql.example.com
DATABASE_PORT=3306
DATABASE_NAME=serialcommander
DATABASE_USERNAME=app_user
DATABASE_PASSWORD=change-me

JWT_SECRET=minimum-32-chars-random-hex
SESSION_SECRET=minimum-32-chars-random-hex

FRONTEND_URL=https://serial.example.com
FRONTEND_URLS=https://serial.example.com
API_BASE_URL=https://api.example.com/serialcommander

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://api.example.com/serialcommander/api/auth/google/callback

# Email thật — bắt buộc App Password (16 ký tự), KHÔNG dùng mật khẩu đăng nhập Gmail
EMAIL_DEV_LOG_OTP=false
GMAIL_USER=your@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
EMAIL_FROM="Serial Commander <noreply@example.com>"
APP_NAME=Serial Commander

# Redis (khuyến nghị production)
RATE_LIMIT_REDIS_URL=redis://127.0.0.1:6379/0
SESSION_REDIS_URL=redis://127.0.0.1:6379/1
REMOTE_SESSION_REDIS_URL=redis://127.0.0.1:6379/4
SCENARIO_OUTBOX_REDIS_URL=redis://127.0.0.1:6379/3
SCENARIO_OUTBOX_WORKER_ENABLED=true
SCENARIO_SYNC_JOB_ENABLED=false

FIREBASE_SERVICE_ACCOUNT_PATH=firebase_mgnt/serviceAccountKey.json

# Mosquitto trên cùng VPS (nếu có remote MQTT)
# MQTT_PASSWD_FILE=/path/to/mosquitto/passwd
