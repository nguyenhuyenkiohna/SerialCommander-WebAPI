{
  "name": "nodejs-core",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build": "node -e \"console.log('Web API has no compile step (Express). Before deploy run: npm test'); process.exit(0)\"",
    "start": "NODE_ENV=production node server.js",
    "start:prod": "NODE_ENV=production node server.js",
    "start:local": "NODE_ENV=development node server.js",
    "dev": "NODE_ENV=development nodemon server.js",
    "dev:local": "NODE_ENV=development nodemon server.js",
    "start:dev": "env-cmd -f .env.local -- nodemon server.js",
    "secrets": "node scripts/generate-secrets.js",
    "test": "jest --detectOpenHandles --verbose --forceExit",
    "test:unit": "jest --config jest.unit.config.js --detectOpenHandles --verbose --forceExit",
    "test:coverage": "jest --coverage --runInBand",
    "openapi:generate": "node scripts/generate-openapi.js",
    "openapi:check": "npm run openapi:generate && git diff --exit-code -- openapi/openapi.json",
    "preflight": "NODE_ENV=production node scripts/preflight.js",
    "deploy": "python3 release_deploy.py",
    "release": "npm run build && npm run deploy"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@opentelemetry/auto-instrumentations-node": "^0.75.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.217.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-node": "^0.217.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "bcryptjs": "^2.4.3",
    "body-parser": "^1.20.2",
    "connect-redis": "^9.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-async-errors": "^3.1.1",
    "express-router-group": "^0.1.4",
    "express-session": "^1.18.2",
    "express-validator": "^7.0.1",
    "firebase-admin": "^13.7.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "json-source-map": "^0.6.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.9.7",
    "nodemailer": "^7.0.11",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "rootpath": "^0.1.2",
    "sequelize": "^6.37.5",
    "slugify": "^1.6.6",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "zod": "^4.4.3"
  },
  "overrides": {
    "jwa": "^2.0.1"
  },
  "devDependencies": {
    "env-cmd": "^11.0.0",
    "git-branch-is": "^4.0.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "sequelize-cli": "^6.6.2",
    "supertest": "^7.0.0",
    "umzug": "^3.8.0"
  }
